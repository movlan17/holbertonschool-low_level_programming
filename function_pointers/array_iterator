#include "function_pointers.h"
#include <stddef.h>

/**
 * array_iterator - dizinin her elemanına fonksiyon uygular
 * @array: tamsayı dizisi
 * @size: dizinin eleman sayısı
 * @action: uygulanacak fonksiyonun işaretçisi
 *
 * Return: hiçbir şey döndürmez
 */
void array_iterator(int *array, size_t size, void (*action)(int))
{
	size_t i;

	if (array && action)
	{
		for (i = 0; i < size; i++)
			action(array[i]);
	}
}

